                    TweenService:Create(OptionBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
                end)

                OptionBtn.MouseLeave:Connect(function()
                    TweenService:Create(OptionBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(10, 10, 10)}):Play()
                end)
            end

            SelectBtn.MouseButton1Click:Connect(function()
                dropOpen = not dropOpen
                if dropOpen then
                    DropFrame.Size = UDim2.new(1, -24, 0, 0)
                    DropFrame.Visible = true
                    TweenService:Create(DropFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -24, 0, #options * 28)}):Play()
                else
                    TweenService:Create(DropFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -24, 0, 0)}):Play()
                    task.delay(0.15, function() DropFrame.Visible = false end)
                end
            end)
        end

        return Tab
    end

    return Window
end

return RyuuLib
