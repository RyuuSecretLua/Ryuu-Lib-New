                Sidebar.Visible = false
                ContentArea.Visible = false
                SideDivider.Visible = false
            end)
        else
            Sidebar.Visible = true
            ContentArea.Visible = true
            SideDivider.Visible = true
            TweenService:Create(BorderFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(0, 504, 0, 344)}):Play()
        end
    end)

