local function makeSplash(title, animName, animText, callback)
    local Splash = Instance.new("Frame")
    Splash.Size = UDim2.new(0, 380, 0, 180)
    Splash.Position = UDim2.new(0.5, -190, 0.5, -90)
    Splash.BackgroundColor3 = BG_MAIN
    Splash.BackgroundTransparency = 1
    Splash.BorderSizePixel = 0
    Splash.ZIndex = 100
    Splash.Parent = ScreenGui

    Instance.new("UICorner", Splash).CornerRadius = UDim.new(0, 12)

    local BorderOuter = Instance.new("UIStroke")
    BorderOuter.Color = BLUE
    BorderOuter.Thickness = 2
    BorderOuter.Parent = Splash

    local EmojiLabel = Instance.new("TextLabel")
    EmojiLabel.Size = UDim2.new(0, 60, 0, 60)
    EmojiLabel.Position = UDim2.new(0.5, -30, 0, 20)
    EmojiLabel.BackgroundTransparency = 1
    EmojiLabel.Text = "⚡"
    EmojiLabel.TextColor3 = BLUE
    EmojiLabel.Font = Enum.Font.GothamBold
    EmojiLabel.TextSize = 36
    EmojiLabel.ZIndex = 101
    EmojiLabel.Parent = Splash

    local RyuuLabel = Instance.new("TextLabel")
    RyuuLabel.Size = UDim2.new(1, 0, 0, 28)
    RyuuLabel.Position = UDim2.new(0, 0, 0, 82)
    RyuuLabel.BackgroundTransparency = 1
    RyuuLabel.Text = animText
    RyuuLabel.TextColor3 = TEXT_BLUE
    RyuuLabel.Font = Enum.Font.Code
    RyuuLabel.TextSize = 0
    RyuuLabel.TextTransparency = 1
    RyuuLabel.ZIndex = 101
    RyuuLabel.Parent = Splash

    local SubLabel = Instance.new("TextLabel")
    SubLabel.Size = UDim2.new(1, 0, 0, 20)
    SubLabel.Position = UDim2.new(0, 0, 0, 114)
    SubLabel.BackgroundTransparency = 1
    SubLabel.Text = title
    SubLabel.TextColor3 = Color3.fromRGB(100, 160, 220)
    SubLabel.Font = Enum.Font.Code
    SubLabel.TextSize = 0
    SubLabel.TextTransparency = 1
    SubLabel.ZIndex = 101
    SubLabel.Parent = Splash

    local AnimLabel = Instance.new("TextLabel")
    AnimLabel.Size = UDim2.new(1, 0, 0, 16)
    AnimLabel.Position = UDim2.new(0, 0, 0, 138)
    AnimLabel.BackgroundTransparency = 1
    AnimLabel.Text = animName
    AnimLabel.TextColor3 = BLUE_DIM
    AnimLabel.Font = Enum.Font.Code
    AnimLabel.TextSize = 12
    AnimLabel.TextTransparency = 1
    AnimLabel.ZIndex = 101
    AnimLabel.Parent = Splash

    local rotation = 0
    local spinConn
    spinConn = RunService.Heartbeat:Connect(function(dt)
        rotation = rotation + dt * 300
        EmojiLabel.Rotation = rotation
        EmojiLabel.TextColor3 = BLUE
    end)

    TweenService:Create(Splash, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {BackgroundTransparency = 0}):Play()

    task.delay(0.3, function()
        TweenService:Create(RyuuLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {TextSize = 22, TextTransparency = 0}):Play()
    end)

    task.delay(0.55, function()
        TweenService:Create(SubLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {TextSize = 15, TextTransparency = 0}):Play()
    end)

    task.delay(0.75, function()
        TweenService:Create(AnimLabel, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {TextTransparency = 0}):Play()
    end)

    task.delay(2.2, function()
        spinConn:Disconnect()
        TweenService:Create(EmojiLabel, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(RyuuLabel, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(SubLabel, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(AnimLabel, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(Splash, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {BackgroundTransparency = 1}):Play()
        task.delay(0.45, function()
            Splash:Destroy()
            callback()
        end)
    end)
end

