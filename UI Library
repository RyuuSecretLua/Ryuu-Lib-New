local function makeSplash(title, callback)
    local Splash = Instance.new("Frame")
    Splash.Size = UDim2.new(1, 0, 1, 0)
    Splash.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    Splash.BackgroundTransparency = 0
    Splash.BorderSizePixel = 0
    Splash.ZIndex = 100
    Splash.Parent = ScreenGui

    local SplashLabel = Instance.new("TextLabel")
    SplashLabel.Size = UDim2.new(1, 0, 0, 40)
    SplashLabel.Position = UDim2.new(0, 0, 0.5, -20)
    SplashLabel.BackgroundTransparency = 1
    SplashLabel.Text = "⚡ Ryuu Lib"
    SplashLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    SplashLabel.Font = Enum.Font.GothamBold
    SplashLabel.TextSize = 0
    SplashLabel.ZIndex = 101
    SplashLabel.Parent = Splash

    local SubLabel = Instance.new("TextLabel")
    SubLabel.Size = UDim2.new(1, 0, 0, 24)
    SubLabel.Position = UDim2.new(0, 0, 0.5, 26)
    SubLabel.BackgroundTransparency = 1
    SubLabel.Text = title
    SubLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
    SubLabel.Font = Enum.Font.Gotham
    SubLabel.TextSize = 0
    SubLabel.ZIndex = 101
    SubLabel.Parent = Splash

    TweenService:Create(SplashLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {TextSize = 28}):Play()
    task.delay(0.2, function()
        TweenService:Create(SubLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {TextSize = 16}):Play()
    end)

    task.delay(1.6, function()
        TweenService:Create(Splash, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {BackgroundTransparency = 1}):Play()
        TweenService:Create(SplashLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()
        TweenService:Create(SubLabel, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {TextTransparency = 1}):Play()
        task.delay(0.5, function()
            Splash:Destroy()
            callback()
        end)
    end)
end

