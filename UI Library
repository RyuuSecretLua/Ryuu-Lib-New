        function Tab:CreateSlider(config)
            local label = config.Name or "Slider"
            local min = config.Min or 0
            local max = config.Max or 100
            local default = math.clamp(config.Default or min, min, max)
            local callback = config.Callback or function() end

            local Row = Instance.new("Frame")
            Row.Size = UDim2.new(1, 0, 0, 55)
            Row.BackgroundColor3 = BG_CARD
            Row.BorderSizePixel = 0
            Row.LayoutOrder = getOrder()
            Row.Parent = TabContent

            Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 6)

            local SRowStroke = Instance.new("UIStroke")
            SRowStroke.Color = BLUE_DIM
            SRowStroke.Thickness = 1
            SRowStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            SRowStroke.Parent = Row

            local LabelTop = Instance.new("TextLabel")
            LabelTop.Size = UDim2.new(1, -12, 0, 22)
            LabelTop.Position = UDim2.new(0, 12, 0, 4)
            LabelTop.BackgroundTransparency = 1
            LabelTop.Text = label .. ":  " .. tostring(default)
            LabelTop.TextColor3 = TEXT_BLUE
            LabelTop.Font = Enum.Font.Code
            LabelTop.TextSize = 13
            LabelTop.TextXAlignment = Enum.TextXAlignment.Left
            LabelTop.Parent = Row

            local Track = Instance.new("Frame")
            Track.Size = UDim2.new(1, -24, 0, 6)
            Track.Position = UDim2.new(0, 12, 0, 36)
            Track.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
            Track.BorderSizePixel = 0
            Track.Parent = Row

            Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

            local defaultRatio = (default - min) / (max - min)

            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new(defaultRatio, 0, 1, 0)
            Fill.BackgroundColor3 = BLUE
            Fill.BorderSizePixel = 0
            Fill.Parent = Track

            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local Thumb = Instance.new("Frame")
            Thumb.Size = UDim2.new(0, 14, 0, 14)
            Thumb.Position = UDim2.new(defaultRatio, -7, 0.5, -7)
            Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Thumb.BorderSizePixel = 0
            Thumb.ZIndex = 4
            Thumb.Parent = Track

            Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)

            local sliding = false

            local function updateSlider(inputX)
                local trackAbsPos = Track.AbsolutePosition.X
                local trackAbsSize = Track.AbsoluteSize.X
                local ratio = math.clamp((inputX - trackAbsPos) / trackAbsSize, 0, 1)
                local value = math.floor(min + (max - min) * ratio)
                Fill.Size = UDim2.new(ratio, 0, 1, 0)
                Thumb.Position = UDim2.new(ratio, -7, 0.5, -7)
                LabelTop.Text = label .. ":  " .. tostring(value)
                callback(value)
            end

            Track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                    updateSlider(input.Position.X)
                end
            end)

            Thumb.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = true
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    updateSlider(input.Position.X)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliding = false
                end
            end)
        end

        function Tab:CreateInput(config)
            local label = config.Name or "Input"
            local placeholder = config.Placeholder or "Type here..."
            local callback = config.Callback or function() end

            local Row = Instance.new("Frame")
            Row.Size = UDim2.new(1, 0, 0, 55)
            Row.BackgroundColor3 = BG_CARD
            Row.BorderSizePixel = 0
            Row.LayoutOrder = getOrder()
            Row.Parent = TabContent

            Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 6)

            local IStroke = Instance.new("UIStroke")
            IStroke.Color = BLUE_DIM
            IStroke.Thickness = 1
            IStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            IStroke.Parent = Row

            local LabelTop = Instance.new("TextLabel")
            LabelTop.Size = UDim2.new(1, -12, 0, 20)
            LabelTop.Position = UDim2.new(0, 12, 0, 4)
            LabelTop.BackgroundTransparency = 1
            LabelTop.Text = label
            LabelTop.TextColor3 = TEXT_BLUE
            LabelTop.Font = Enum.Font.Code
            LabelTop.TextSize = 13
            LabelTop.TextXAlignment = Enum.TextXAlignment.Left
            LabelTop.Parent = Row

            local InputBox = Instance.new("TextBox")
            InputBox.Size = UDim2.new(1, -24, 0, 22)
            InputBox.Position = UDim2.new(0, 12, 0, 27)
            InputBox.BackgroundColor3 = Color3.fromRGB(5, 5, 10)
            InputBox.Text = ""
            InputBox.PlaceholderText = placeholder
            InputBox.PlaceholderColor3 = BLUE_DIM
            InputBox.TextColor3 = TEXT_BLUE
            InputBox.Font = Enum.Font.Code
            InputBox.TextSize = 12
            InputBox.BorderSizePixel = 0
            InputBox.ClearTextOnFocus = false
            InputBox.Parent = Row

            Instance.new("UICorner", InputBox).CornerRadius = UDim.new(0, 4)

            local IBStroke = Instance.new("UIStroke")
            IBStroke.Color = BLUE
            IBStroke.Thickness = 1
            IBStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            IBStroke.Parent = InputBox

            local P = Instance.new("UIPadding")
            P.PaddingLeft = UDim.new(0, 6)
            P.Parent = InputBox

            InputBox.FocusLost:Connect(function(enter)
                if enter then callback(InputBox.Text) end
            end)
        end

        function Tab:CreateSelect(config)
            local label = config.Name or "Select"
            local options = config.Options or {}
            local callback = config.Callback or function() end

            local Row = Instance.new("Frame")
            Row.Size = UDim2.new(1, 0, 0, 55)
            Row.BackgroundColor3 = BG_CARD
            Row.BorderSizePixel = 0
            Row.LayoutOrder = getOrder()
            Row.ClipsDescendants = false
            Row.Parent = TabContent

            Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 6)

            local SelStroke = Instance.new("UIStroke")
            SelStroke.Color = BLUE_DIM
            SelStroke.Thickness = 1
            SelStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            SelStroke.Parent = Row

            local LabelTop = Instance.new("TextLabel")
            LabelTop.Size = UDim2.new(1, -12, 0, 20)
            LabelTop.Position = UDim2.new(0, 12, 0, 4)
            LabelTop.BackgroundTransparency = 1
            LabelTop.Text = label
            LabelTop.TextColor3 = TEXT_BLUE
            LabelTop.Font = Enum.Font.Code
            LabelTop.TextSize = 13
            LabelTop.TextXAlignment = Enum.TextXAlignment.Left
            LabelTop.Parent = Row

            local SelectBtn = Instance.new("TextButton")
            SelectBtn.Size = UDim2.new(1, -24, 0, 22)
            SelectBtn.Position = UDim2.new(0, 12, 0, 27)
            SelectBtn.BackgroundColor3 = Color3.fromRGB(5, 5, 10)
            SelectBtn.Text = options[1] or "Select..."
            SelectBtn.TextColor3 = TEXT_BLUE
            SelectBtn.Font = Enum.Font.Code
            SelectBtn.TextSize = 12
            SelectBtn.BorderSizePixel = 0
            SelectBtn.Parent = Row

            Instance.new("UICorner", SelectBtn).CornerRadius = UDim.new(0, 4)

            local SBStroke = Instance.new("UIStroke")
            SBStroke.Color = BLUE
            SBStroke.Thickness = 1
            SBStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            SBStroke.Parent = SelectBtn

            local dropOpen = false

            local DropFrame = Instance.new("Frame")
            DropFrame.Size = UDim2.new(1, -24, 0, 0)
            DropFrame.Position = UDim2.new(0, 12, 1, 4)
            DropFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 10)
            DropFrame.BorderSizePixel = 0
            DropFrame.Visible = false
            DropFrame.ZIndex = 10
            DropFrame.ClipsDescendants = true
            DropFrame.Parent = Row

            Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0, 4)

            local DFStroke = Instance.new("UIStroke")
            DFStroke.Color = BLUE
            DFStroke.Thickness = 1
            DFStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            DFStroke.Parent = DropFrame

            local DropList = Instance.new("UIListLayout")
            DropList.SortOrder = Enum.SortOrder.LayoutOrder
            DropList.Parent = DropFrame

            for i, opt in ipairs(options) do
                local OptionBtn = Instance.new("TextButton")
                OptionBtn.Size = UDim2.new(1, 0, 0, 28)
                OptionBtn.BackgroundColor3 = Color3.fromRGB(5, 5, 10)
                OptionBtn.Text = opt
                OptionBtn.TextColor3 = TEXT_BLUE
                OptionBtn.Font = Enum.Font.Code
                OptionBtn.TextSize = 12
                OptionBtn.BorderSizePixel = 0
                OptionBtn.LayoutOrder = i
                OptionBtn.ZIndex = 11
                OptionBtn.Parent = DropFrame

                OptionBtn.MouseButton1Click:Connect(function()
                    SelectBtn.Text = opt
                    TweenService:Create(DropFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -24, 0, 0)}):Play()
                    task.delay(0.15, function() DropFrame.Visible = false end)
                    dropOpen = false
                    callback(opt)
                end)

                OptionBtn.MouseEnter:Connect(function()
                    TweenService:Create(OptionBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(15, 20, 35)}):Play()
                end)

                OptionBtn.MouseLeave:Connect(function()
                    TweenService:Create(OptionBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(5, 5, 10)}):Play()
                end)
            end

            SelectBtn.MouseButton1Click:Connect(function()
                dropOpen = not dropOpen
                if dropOpen then
                    DropFrame.Visible = true
                    TweenService:Create(DropFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -24, 0, #options * 28)}):Play()
                else
                    TweenService:Create(DropFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(1, -24, 0, 0)}):Play()
                    task.delay(0.15, function() DropFrame.Visible = false end)
                end
            end)
        end

        return Tab
    end

    return Window
end

return RyuuLib
